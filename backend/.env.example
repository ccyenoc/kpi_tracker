# Firebase settings (REQUIRED - Copy from Firebase Console)
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_DATABASE_URL=https://your-project-rtdb.region.firebasedatabase.app
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
FIREBASE_APP_ID=your_firebase_app_id
FIREBASE_MEASUREMENT_ID=your_measurement_id
SERVICE_ACCOUNT_KEY_PATH=serviceAccountKey.json

# Firestore collections (default names - change if you use different collection names)
USERDATA_COLLECTION=userData
USERAUTH_COLLECTION=userAuth
USER_COUNTER_COLLECTION=systemCounters
USER_COUNTER_DOC=userIdCounter
EMAIL_VERIFICATION_COLLECTION=emailVerifications

# Email verification settings
VERIFICATION_CODE_TTL_SECONDS=600

# SMTP settings (REQUIRED - Use your email provider credentials)
# For Gmail: set SMTP_HOST=smtp.gmail.com, SMTP_PORT=587
# For Outlook: set SMTP_HOST=smtp.office365.com, SMTP_PORT=587
# For SendGrid: set SMTP_HOST=smtp.sendgrid.net, SMTP_PORT=587
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_or_auth_key
SMTP_FROM=your_email@gmail.com
SMTP_USE_TLS=true

